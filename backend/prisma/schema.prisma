generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== USERS =====================

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  phone             String?  @unique
  name              String
  passwordHash      String
  avatarUrl         String?
  deviceFingerprint String?
  ipHistory         String[]
  isVerified        Boolean  @default(false)
  isBanned          Boolean  @default(false)
  fraudScore        Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  bookings           Booking[]
  hostedEvents       Event[]           @relation("EventHost")
  eventAttendances   EventAttendee[]
  loyaltyAccount     LoyaltyAccount?
  voucherRedemptions VoucherRedemption[]

  @@index([email])
  @@index([phone])
}

// ===================== VENUES =====================

model Venue {
  id          String        @id @default(uuid())
  name        String
  category    VenueCategory
  address     String
  latitude    Float
  longitude   Float
  phone       String
  imageUrls   String[]
  description String?
  openTime    String
  closeTime   String
  totalTables Int
  avgWaitTime Int
  isActive    Boolean       @default(true)
  isPartner   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tables           Table[]
  bookings         Booking[]
  queueSlots       QueueSlot[]
  partnerCampaigns PartnerCampaign[]
  settlementBatches SettlementBatch[]

  @@index([category])
  @@index([isActive])
}

enum VenueCategory {
  RESTAURANT
  BAR
  CAFE
  CLUB
  KARAOKE
  OTHER
}

model Table {
  id          String      @id @default(uuid())
  venueId     String
  tableNumber String
  capacity    Int
  status      TableStatus @default(AVAILABLE)

  venue    Venue     @relation(fields: [venueId], references: [id])
  bookings Booking[]

  @@index([venueId, status])
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

// ===================== QUEUE & BOOKING =====================

model QueueSlot {
  id            String      @id @default(uuid())
  venueId       String
  bookingId     String      @unique
  queueNumber   Int
  estimatedWait Int
  status        QueueStatus @default(WAITING)
  notifiedAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  venue   Venue   @relation(fields: [venueId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([venueId, status])
  @@index([queueNumber])
}

enum QueueStatus {
  WAITING
  CALLED
  SEATED
  EXPIRED
  CANCELLED
}

model Booking {
  id            String        @id @default(uuid())
  userId        String
  venueId       String
  tableId       String?
  partySize     Int
  bookingType   BookingType
  scheduledAt   DateTime?
  status        BookingStatus @default(PENDING)
  checkInAt     DateTime?
  checkOutAt    DateTime?
  depositAmount Decimal?      @db.Decimal(10, 2)
  depositPaid   Boolean       @default(false)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user      User       @relation(fields: [userId], references: [id])
  venue     Venue      @relation(fields: [venueId], references: [id])
  table     Table?     @relation(fields: [tableId], references: [id])
  event     Event?
  queueSlot QueueSlot?

  @@index([userId])
  @@index([venueId, status])
  @@index([scheduledAt])
}

enum BookingType {
  WALK_IN_QUEUE
  ADVANCE_RESERVATION
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ===================== EVENTS (SOCIAL) =====================

model Event {
  id           String      @id @default(uuid())
  bookingId    String      @unique
  hostId       String
  title        String
  description  String?
  inviteToken  String      @unique @default(uuid())
  maxAttendees Int
  status       EventStatus @default(PENDING)
  completedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  booking             Booking              @relation(fields: [bookingId], references: [id])
  host                User                 @relation("EventHost", fields: [hostId], references: [id])
  attendees           EventAttendee[]
  loyaltyTransaction  LoyaltyTransaction?

  @@index([hostId])
  @@index([inviteToken])
}

enum EventStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

model EventAttendee {
  id          String         @id @default(uuid())
  eventId     String
  userId      String
  status      AttendeeStatus @default(INVITED)
  joinedAt    DateTime?
  checkedInAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

enum AttendeeStatus {
  INVITED
  ACCEPTED
  DECLINED
  CHECKED_IN
  NO_SHOW
}

// ===================== LOYALTY SYSTEM =====================

model LoyaltyAccount {
  id              String      @id @default(uuid())
  userId          String      @unique
  tier            LoyaltyTier @default(BRONZE)
  totalPoints     Int         @default(0)
  availablePoints Int         @default(0)
  successfulTrips Int         @default(0)
  lifetimePoints  Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user         User                 @relation(fields: [userId], references: [id])
  transactions LoyaltyTransaction[]

  @@index([userId])
  @@index([tier])
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

model LoyaltyTransaction {
  id            String          @id @default(uuid())
  accountId     String
  eventId       String?         @unique
  type          TransactionType
  points        Int
  balanceBefore Int
  balanceAfter  Int
  description   String
  expiresAt     DateTime?
  createdAt     DateTime        @default(now())

  account LoyaltyAccount @relation(fields: [accountId], references: [id])
  event   Event?         @relation(fields: [eventId], references: [id])

  @@index([accountId])
  @@index([createdAt])
  @@index([expiresAt])
}

enum TransactionType {
  EARN_TRIP_COMPLETE
  EARN_MILESTONE_BONUS
  EARN_REFERRAL
  REDEEM_VOUCHER
  EXPIRE
  ADJUST_ADMIN
}

model RewardCatalog {
  id              String       @id @default(uuid())
  title           String
  description     String
  imageUrl        String?
  pointsCost      Int
  discountValue   Decimal      @db.Decimal(10, 2)
  discountType    DiscountType
  validityDays    Int
  isActive        Boolean      @default(true)
  stock           Int?
  redemptionCount Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  voucherRedemptions VoucherRedemption[]
  partnerCampaigns   PartnerCampaign[]
}

enum DiscountType {
  FIXED_AMOUNT
  PERCENTAGE
  FREE_ITEM
}

model VoucherRedemption {
  id                String        @id @default(uuid())
  userId            String
  rewardId          String
  venueId           String?
  voucherCode       String        @unique @default(uuid())
  pointsUsed        Int
  discountValue     Decimal       @db.Decimal(10, 2)
  status            VoucherStatus @default(ISSUED)
  issuedAt          DateTime      @default(now())
  expiresAt         DateTime
  usedAt            DateTime?
  settledAt         DateTime?
  settlementBatchId String?

  user            User             @relation(fields: [userId], references: [id])
  reward          RewardCatalog    @relation(fields: [rewardId], references: [id])
  settlementBatch SettlementBatch? @relation(fields: [settlementBatchId], references: [id])

  @@index([userId])
  @@index([voucherCode])
  @@index([status])
  @@index([settlementBatchId])
}

enum VoucherStatus {
  ISSUED
  USED
  EXPIRED
  CANCELLED
}

model PartnerCampaign {
  id              String   @id @default(uuid())
  venueId         String
  rewardId        String
  title           String
  budgetAmount    Decimal  @db.Decimal(12, 2)
  spentAmount     Decimal  @db.Decimal(12, 2) @default(0)
  platformFeeRate Decimal  @db.Decimal(5, 4)
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  venue  Venue         @relation(fields: [venueId], references: [id])
  reward RewardCatalog @relation(fields: [rewardId], references: [id])

  @@index([venueId, isActive])
}

model SettlementBatch {
  id               String           @id @default(uuid())
  venueId          String
  periodStart      DateTime
  periodEnd        DateTime
  totalRedemptions Int
  totalDiscount    Decimal          @db.Decimal(12, 2)
  platformFee      Decimal          @db.Decimal(12, 2)
  venuePayable     Decimal          @db.Decimal(12, 2)
  status           SettlementStatus @default(PENDING)
  settledAt        DateTime?
  createdAt        DateTime         @default(now())

  venue       Venue               @relation(fields: [venueId], references: [id])
  redemptions VoucherRedemption[]

  @@index([venueId, status])
}

enum SettlementStatus {
  PENDING
  PROCESSING
  COMPLETED
  DISPUTED
}

// ===================== ANTI-FRAUD =====================

model FraudLog {
  id        String   @id @default(uuid())
  userId    String?
  ipAddress String
  deviceId  String?
  action    String
  riskScore Int
  details   Json
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([ipAddress])
  @@index([createdAt])
}
